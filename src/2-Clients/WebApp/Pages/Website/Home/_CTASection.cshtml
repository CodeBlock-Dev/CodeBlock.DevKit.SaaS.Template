<section class="py-5" style="background: var(--gradient-primary);">
    <div class="container">
        <div class="row justify-content-center">
            <div class="col-lg-8 text-center">
                <h2 class="mb-4 text-white">@WebAppLocalizer[WebAppResource.CTA_Final_Title]</h2>
                <p class="lead text-white mb-4">
                    @Html.Raw(WebAppLocalizer[WebAppResource.CTA_Final_Description])
                </p>

                <!-- Steps Guide -->
                <div class="row g-3 mb-5 text-start">
                    <div class="col-12 text-center mb-3">
                        <h5 class="fw-bold startup-steps-title">@WebAppLocalizer[WebAppResource.Steps_Section_Title]</h5>
                    </div>

                    <div class="col-md-4 col-sm-6">
                        <div class="p-3 rounded-3 h-100 startup-step-card">
                            <div class="d-flex align-items-start text-white">
                                <div class="rounded-circle bg-light text-primary fw-bold me-3 d-flex align-items-center justify-content-center flex-shrink-0 step-number-circle">1</div>
                                <div>
                                    <h6 class="mb-2">@WebAppLocalizer[WebAppResource.Step_1_Title]</h6>
                                    <p class="text-white-50 mb-2 step-description">@WebAppLocalizer[WebAppResource.Step_1_Description]</p>
                                    <a href="https://docs.codeblock.dev/" class="btn btn-outline-light btn-sm" target="_blank">
                                        <i class="bi bi-book"></i> @WebAppLocalizer[WebAppResource.Step_1_Button]
                                    </a>
                                </div>
                            </div>
                        </div>
                    </div>

                    <div class="col-md-4 col-sm-6">
                        <div class="p-3 rounded-3 h-100 startup-step-card">
                            <div class="d-flex align-items-start text-white">
                                <div class="rounded-circle bg-light text-primary fw-bold me-3 d-flex align-items-center justify-content-center flex-shrink-0 step-number-circle">2</div>
                                <div>
                                    <h6 class="mb-2">@WebAppLocalizer[WebAppResource.Step_2_Title]</h6>
                                    <p class="text-white-50 mb-0 step-description">@WebAppLocalizer[WebAppResource.Step_2_Description]</p>
                                </div>
                            </div>
                        </div>
                    </div>

                    <div class="col-md-4 col-sm-6">
                        <div class="p-3 rounded-3 h-100 startup-step-card">
                            <div class="d-flex align-items-start text-white">
                                <div class="rounded-circle bg-light text-primary fw-bold me-3 d-flex align-items-center justify-content-center flex-shrink-0 step-number-circle">3</div>
                                <div>
                                    <h6 class="mb-2">@WebAppLocalizer[WebAppResource.Step_3_Title]</h6>
                                    <p class="text-white-50 mb-0 step-description">@WebAppLocalizer[WebAppResource.Step_3_Description]</p>
                                </div>
                            </div>
                        </div>
                    </div>

                    <div class="col-md-4 col-sm-6">
                        <div class="p-3 rounded-3 h-100 startup-step-card">
                            <div class="d-flex align-items-start text-white">
                                <div class="rounded-circle bg-light text-primary fw-bold me-3 d-flex align-items-center justify-content-center flex-shrink-0 step-number-circle">4</div>
                                <div>
                                    <h6 class="mb-2">@WebAppLocalizer[WebAppResource.Step_4_Title]</h6>
                                    <p class="text-white-50 mb-0 step-description">@WebAppLocalizer[WebAppResource.Step_4_Description]</p>
                                </div>
                            </div>
                        </div>
                    </div>

                    <div class="col-md-4 col-sm-6">
                        <div class="p-3 rounded-3 h-100 startup-step-card">
                            <div class="d-flex align-items-start text-white">
                                <div class="rounded-circle bg-light text-primary fw-bold me-3 d-flex align-items-center justify-content-center flex-shrink-0 step-number-circle">5</div>
                                <div>
                                    <h6 class="mb-2">@WebAppLocalizer[WebAppResource.Step_5_Title]</h6>
                                    <p class="text-white-50 mb-0 step-description">@WebAppLocalizer[WebAppResource.Step_5_Description]</p>
                                </div>
                            </div>
                        </div>
                    </div>

                    <div class="col-md-4 col-sm-6">
                        <div class="p-3 rounded-3 h-100 startup-step-card">
                            <div class="d-flex align-items-start text-white">
                                <div class="rounded-circle bg-light text-primary fw-bold me-3 d-flex align-items-center justify-content-center flex-shrink-0 step-number-circle">6</div>
                                <div>
                                    <h6 class="mb-2">@WebAppLocalizer[WebAppResource.Step_6_Title]</h6>
                                    <p class="text-white-50 mb-0 step-description">@WebAppLocalizer[WebAppResource.Step_6_Description]</p>
                                </div>
                            </div>
                        </div>
                    </div>
                </div>

                <!-- Video Demo -->
                <div class="mb-4">
                    <div class="p-4 rounded-4 position-relative overflow-hidden video-demo-container">
                        <div class="position-absolute top-0 end-0 mt-2 me-2">
                            <i class="bi bi-star-fill text-warning video-star-icon"></i>
                        </div>
                        <div class="text-center">
                            <div class="d-flex justify-content-center align-items-center mb-3">
                                <i class="bi bi-play-circle-fill text-warning me-2 video-play-icon"></i>
                                <h4 class="mb-0 fw-bold video-title">@WebAppLocalizer[WebAppResource.Video_Section_Title]</h4>
                            </div>
                            <p class="text-white mb-4 video-description">
                                @WebAppLocalizer[WebAppResource.Video_Section_Description]
                            </p>
                            <a href="#demo-video-link" class="btn btn-warning btn-lg px-4 py-3 fw-bold shadow-lg video-button" target="_blank">
                                <i class="bi bi-play-circle-fill me-2"></i> @WebAppLocalizer[WebAppResource.Video_Button_Text]
                            </a>
                            <div class="mt-3">
                                <small class="text-warning">
                                    <i class="bi bi-clock"></i> @WebAppLocalizer[WebAppResource.Video_Section_Subtitle]
                                </small>
                            </div>
                        </div>
                    </div>
                </div>
            </div>
        </div>
    </div>
</section>