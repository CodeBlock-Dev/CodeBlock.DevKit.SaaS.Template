
<section id="home" class="hero-section">
    <div class="hero-background">
        <div class="floating-shapes">
            <div class="shape shape-1"></div>
            <div class="shape shape-2"></div>
            <div class="shape shape-3"></div>
        </div>
    </div>
    <div class="container">
        <div class="row justify-content-center">
            <div class="col-lg-10 text-center hero-content">

                <h1 class="hero-title fade-in">@WebAppLocalizer[WebAppResource.Hero_Tagline]</h1>
                <p class="hero-tagline fade-in">@WebAppLocalizer[WebAppResource.Hero_Title]</p>

                <p class="hero-subtitle fade-in">
                    @Html.Raw(WebAppLocalizer[WebAppResource.Hero_Subtitle])
                </p>

                <!-- System Access Cards -->
                <div class="row g-3 mb-4 fade-in justify-content-center">
                    <div class="col-12 mb-2">
                        <small class="text-info"><i class="bi bi-cursor"></i> <strong>@WebAppLocalizer[WebAppResource.System_Access_Title]</strong> @WebAppLocalizer[WebAppResource.System_Access_Subtitle]</small>
                    </div>
                    <div class="col-md-2 col-6">
                        <div class="system-access-card">
                            <a href="/" class="text-decoration-none">
                                <div class="access-icon">
                                    <i class="bi bi-globe"></i>
                                </div>
                                <div class="access-label">@WebAppLocalizer[WebAppResource.System_Website]</div>
                                <div class="access-status">@WebAppLocalizer[WebAppResource.System_Website_Status]</div>
                            </a>
                        </div>
                    </div>
                    <div class="col-md-2 col-6">
                        <div class="system-access-card">
                            <a href="/dashboard" target="_blank" class="text-decoration-none">
                                <div class="access-icon">
                                    <i class="bi bi-person-workspace"></i>
                                </div>
                                <div class="access-label">@WebAppLocalizer[WebAppResource.System_UserPanel]</div>
                                <div class="access-status">@WebAppLocalizer[WebAppResource.System_UserPanel_Status]</div>
                            </a>
                        </div>
                    </div>
                    <div class="col-md-2 col-6">
                        <div class="system-access-card">
                            <a href="http://localhost:50004" target="_blank" class="text-decoration-none">
                                <div class="access-icon">
                                    <i class="bi bi-speedometer2"></i>
                                </div>
                                <div class="access-label">@WebAppLocalizer[WebAppResource.System_AdminPanel]</div>
                                <div class="access-status">@WebAppLocalizer[WebAppResource.System_AdminPanel_Status]</div>
                                <div class="mt-1">
                                    <small class="text-secondary d-block" style="font-size: 0.65rem;">
                                        username: @Configuration["Identity:AdminUser:Email"]
                                    </small>
                                    <small class="text-secondary d-block" style="font-size: 0.65rem;">
                                        password: @Configuration["Identity:AdminUser:Password"]
                                    </small>
                                </div>
                            </a>
                        </div>
                    </div>
                    <div class="col-md-2 col-6">
                        <div class="system-access-card">
                            <a href="http://localhost:50005" target="_blank" class="text-decoration-none">
                                <div class="access-icon">
                                    <i class="bi bi-code-square"></i>
                                </div>
                                <div class="access-label">@WebAppLocalizer[WebAppResource.System_API]</div>
                                <div class="access-status">@WebAppLocalizer[WebAppResource.System_API_Status]</div>
                            </a>
                        </div>
                    </div>
                    <div class="col-md-2 col-6">
                        <div class="system-access-card">
                            <a href="/ai/bot/chat/" target="_blank" class="text-decoration-none">
                                <div class="access-icon">
                                    <i class="bi bi-robot"></i>
                                </div>
                                <div class="access-label">@WebAppLocalizer[WebAppResource.System_ChatBot]</div>
                                <div class="access-status">@WebAppLocalizer[WebAppResource.System_ChatBot_Status]</div>
                            </a>
                        </div>
                    </div>
                </div>
            </div>
        </div>
    </div>
</section>